{
  "name": "hushh-technologies",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "PORT=3005 node server.js",
    "dev:vercel": "vercel dev --listen 3000",
    "dco:check": "bash scripts/ci/check-dco.sh",
    "env:check": "node scripts/ci/check-env-contract.mjs",
    "lint:ci": "bash scripts/ci/lint-ci.sh",
    "pr:hygiene": "node scripts/ci/check-pr-hygiene.mjs",
    "security:gitleaks": "bash scripts/security/run-gitleaks.sh",
    "security:audit": "bash scripts/security/open-source-audit.sh",
    "security:pre-commit": "PRE_COMMIT_HOME=.pre-commit-cache pre-commit run --all-files",
    "security:rewrite-history": "bash scripts/security/rewrite-history.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "build:assets": "node scripts/generate-sitemap.js && node scripts/generate-robots.js",
    "build:web": "npm run build:assets && vite build",
    "build": "vitest run && npm run build:web",
    "preview": "vite preview",
    "smoke:ci": "bash scripts/ci/run-smoke.sh",
    "test:e2e": "npx playwright test",
    "test:e2e:deepsearch": "npx playwright test deepsearch",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "test:e2e:report": "npx playwright show-report",
    "test:e2e:debug": "npx playwright test --debug"
  },
